HOST=127.0.0.1
PORT=4020
LOG_LEVEL=info
# Exact address or CIDR of the only reverse proxy allowed to supply forwarding headers.
TRUSTED_PROXY=

# Keep payments disabled until the dedicated LNbits invoice key and bridge are configured.
PAYMENT_PROVIDER=disabled
# The application accepts loopback HTTP or the pinned Docker gateway bridge at http://172.30.240.1:2180.
PAYMENT_API_URL=
PAYMENT_API_KEY=
# 32 random bytes encoded as base64url; never reuse CATCH_TOKEN_PEPPER.
PAYMENT_DELIVERY_KEY=
# Optional bridge settings; keep the real onion hostname out of Git.
LNBITS_SOCKS_PROXY=127.0.0.1
LNBITS_SOCKS_PORT=9050
LNBITS_ONION_HOST=

# CATCH is enabled only when both values are non-empty.
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://the402machine:change-me@db:5432/the402machine
CATCH_TOKEN_PEPPER=change-me
PUBLIC_BASE_URL=http://127.0.0.1:4020

# Internal fulfilment remains off until the payment broker is connected.
CATCH_INTERNAL_PROVISIONING=false
CATCH_PROVISIONING_SECRET=
