{
  "name": "the402machine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted Lightning-powered vending machine for tiny disposable Internet appliances.",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "migrate": "node scripts/migrate.mjs",
    "worker": "node dist/worker.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "build:qr": "esbuild public/assets/qr.js --bundle --format=esm --platform=browser --target=es2020 --minify --outfile=public/assets/qr-browser-v3.js",
    "build:webln": "esbuild public/assets/webln-entry.js --bundle --format=esm --platform=browser --target=es2020 --minify --outfile=public/assets/webln-browser.js",
    "build:browser": "npm run build:qr && npm run build:webln"
  },
  "dependencies": {
    "@fastify/helmet": "^13.1.0",
    "@fastify/static": "^10.1.2",
    "fast-geoip": "1.1.88",
    "fastify": "5.10.0",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "webln": "^0.3.2"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@types/node": "26.1.1",
    "@types/qrcode": "^1.5.6",
    "esbuild": "^0.28.1",
    "eslint": "9.39.5",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10"
  }
}
