{
  "name": "the402machine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted Lightning-powered vending machine for tiny disposable Internet appliances.",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/helmet": "^13.1.0",
    "@fastify/static": "^10.1.2",
    "fastify": "5.10.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@types/node": "26.1.1",
    "eslint": "9.39.5",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10"
  }
}
